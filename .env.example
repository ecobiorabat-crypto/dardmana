# Database (Prisma / Supabase Postgres)
# Transaction pooler (port 6543) pour l'app
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# Session pooler (port 5432) pour Prisma CLI (migrate, seed)
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Stripe (paiement international — optionnel, COD fonctionne sans)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# PayPal (commandes internationales, pays != MA — facturé en EUR)
# Comment obtenir les identifiants :
#   1. Connectez-vous sur https://developer.paypal.com → Dashboard → Apps & Credentials.
#   2. Choisissez l'onglet « Sandbox » (tests) ou « Live » (production).
#   3. Cliquez « Create App », nommez-la, puis copiez le Client ID et le Secret.
#   4. Le Client ID est public (NEXT_PUBLIC_…) ; le Secret reste strictement serveur.
# PAYPAL_API_BASE est optionnel : laissez vide pour la sandbox, mettez
#   https://api-m.paypal.com pour la production.
PAYPAL_CLIENT_ID=<your-paypal-client-id>
PAYPAL_CLIENT_SECRET=<your-paypal-client-secret>
NEXT_PUBLIC_PAYPAL_CLIENT_ID=<your-paypal-client-id>
# PAYPAL_API_BASE=https://api-m.paypal.com

# Cloudinary (upload images admin)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

# Resend (emails transactionnels)
RESEND_API_KEY=<your-resend-api-key>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Admin (auth JWT). Les comptes admin sont créés en base via: npm run create-admin
ADMIN_JWT_SECRET=<random-64-char-string>

# WhatsApp Business API (optionnel)
WHATSAPP_VERIFY_TOKEN=<your-verify-token>
WHATSAPP_ACCESS_TOKEN=<your-access-token>
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>

# Notification WhatsApp admin via CallMeBot (gratuit, sans WhatsApp Business API).
# Comment obtenir la clé (≈ 2 min) :
#   1. Enregistre le contact +34 644 59 77 81
#   2. Envoie-lui sur WhatsApp : "I allow callmebot.com to send me messages"
#   3. Tu reçois ton apikey en réponse → CALLMEBOT_API_KEY
#   4. CALLMEBOT_PHONE = ton numéro WhatsApp (format international, ex. 2126XXXXXXXX)
# Active ensuite le toggle dans Admin → Paramètres → Notifications WhatsApp.
CALLMEBOT_API_KEY=
CALLMEBOT_PHONE=

# Analytics (laisser vide pour désactiver le chargement des scripts)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Facebook App ID (optionnel) — émet <meta property="fb:app_id"> si renseigné
NEXT_PUBLIC_FB_APP_ID=

# Livre d'Or — réseaux sociaux (liens des bandeaux TikTok / Google)
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@dardmana
# URL publique de la fiche Google (onglet avis) — bouton "Voir"
GOOGLE_REVIEWS_URL=
# Place ID de la fiche Google Business — bouton "Laisser un avis Google"
GOOGLE_PLACE_ID=

# Cron (relance paniers abandonnés) — secret partagé avec Vercel Cron
CRON_SECRET=<long-random-string>

# Chiffrement des secrets stockés en base (clés API transporteurs).
# À défaut, dérivé de ADMIN_JWT_SECRET. Définir une vraie valeur en prod.
ENCRYPTION_KEY=

# Transporteurs (optionnel : sinon saisis via Admin → Paramètres → Livraison)
AMANA_API_KEY=
CTM_API_KEY=
SENDIT_API_KEY=
# Base de l'API Sendit (optionnel ; défaut https://app.sendit.ma/api/v1)
SENDIT_API_BASE=
