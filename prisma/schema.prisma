generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum PaymentMethod {
  COD
  CMI
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderSource {
  SHOP
  WHATSAPP
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SUPPORT
  STOCK
  FINANCE
}

enum PromoType {
  PERCENT
  FIXED_MAD
  FREE_SHIPPING
}

enum NotifChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotifStatus {
  SENT
  FAILED
  PENDING
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  nameFr      String
  nameAr      String
  nameEn      String

  descriptionFr String?
  descriptionAr String?
  descriptionEn String?

  icon     String?
  imageUrl String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  metaTitleFr       String?
  metaDescriptionFr String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id   String  @id @default(cuid())
  slug String  @unique
  sku  String? @unique

  nameFr String
  nameAr String
  nameEn String

  descriptionFr String
  descriptionAr String
  descriptionEn String

  shortDescFr String?
  shortDescAr String?
  shortDescEn String?

  priceMad        Decimal
  priceEur        Decimal?
  comparePriceMad Decimal?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images   String[]
  videoUrl String?

  stock             Int @default(0)
  lowStockThreshold Int @default(5)

  weightG    Int?
  dimensions String?

  materialFr String?
  materialAr String?
  materialEn String?

  status ProductStatus @default(DRAFT)
  type   ProductType   @default(PHYSICAL)

  isFeatured Boolean @default(false)
  isNew      Boolean @default(false)

  tags String[]

  metaTitleFr       String?
  metaTitleAr       String?
  metaTitleEn       String?
  metaDescriptionFr String?
  metaDescriptionAr String?
  metaDescriptionEn String?

  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)
  viewsCount  Int   @default(0)
  salesCount  Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants      ProductVariant[]
  reviews       Review[]
  orderItems    OrderItem[]
  wishlistItems Wishlist[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  nameFr String
  nameAr String
  nameEn String

  sku String? @unique

  priceMad Decimal
  stock    Int

  attributes Json

  isActive Boolean @default(true)

  orderItems OrderItem[]
}

model Customer {
  id         String  @id @default(cuid())
  authUserId String? @unique

  email String?
  name  String
  phone String? @unique

  country           String @default("MA")
  preferredLanguage String @default("fr")

  totalOrders   Int     @default(0)
  totalSpentMad Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders            Order[]
  addresses         Address[]
  reviews           Review[]
  wishlists         Wishlist[]
  notificationLogs  NotificationLog[]
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label     String @default("Domicile")
  fullName  String
  phone     String

  addressLine1 String
  addressLine2 String?

  city       String
  postalCode String?
  region     String?
  country    String  @default("MA")

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(cuid())

  orderNumber String @unique

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  customerName  String
  customerEmail String
  customerPhone String

  shippingAddress Json
  items           Json

  subtotalMad   Decimal
  shippingCostMad Decimal @default(0)
  discountMad   Decimal @default(0)
  totalMad      Decimal
  totalEur      Decimal?

  currency String @default("MAD")

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  stripePaymentIntent String?

  orderStatus OrderStatus @default(NEW)
  source      OrderSource @default(SHOP)

  trackingNumber  String?
  carrier         String?
  deliveryPayload Json?
  deliveryError   String?

  notes      String?
  adminNotes String?

  promoCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems       OrderItem[]
  payments         Payment[]
  trackingEvents   TrackingEvent[]
  statusHistory    OrderStatusHistory[]
  notificationLogs NotificationLog[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName  String
  productImage String

  quantity     Int
  unitPriceMad Decimal
  totalMad     Decimal
}

model OrderStatusHistory {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status    OrderStatus
  note      String?
  changedBy String?

  createdAt DateTime @default(now())
}

model Payment {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method   PaymentMethod
  status   PaymentStatus
  amount   Decimal
  currency String

  providerRef String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingMethod {
  id      String @id @default(cuid())
  name    String
  carrier String

  countries String[]

  priceMad Decimal
  priceEur Decimal?

  minDays Int
  maxDays Int

  freeThresholdMad Decimal?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
}

model TrackingEvent {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status      String
  description String
  location    String?
  carrier     String

  occurredAt DateTime
}

model PromoCode {
  id   String @id @default(cuid())
  code String @unique

  type  PromoType
  value Decimal

  minOrderMad  Decimal @default(0)
  maxUses      Int?
  currentUses  Int     @default(0)
  expiresAt    DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

model Review {
  id         String  @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  customerName    String
  customerCountry String?

  rating  Int
  title   String?
  content String

  isVerified Boolean @default(false)
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
}

model Wishlist {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([customerId, productId])
}

model NotificationLog {
  id         String    @id @default(cuid())
  orderId    String?
  order      Order?    @relation(fields: [orderId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  channel    NotifChannel
  type       String
  recipient  String

  status       NotifStatus @default(PENDING)
  errorMessage String?
  retryCount   Int         @default(0)
  sentAt       DateTime?

  createdAt DateTime @default(now())
}

model AuditLog {
  id         String @id @default(cuid())
  adminEmail String

  action       String
  resourceType String
  resourceId   String

  before    Json?
  after     Json?
  ipAddress String?

  createdAt DateTime @default(now())
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SiteSettings {
  // Singleton : une seule ligne, identifiant fixe "singleton".
  id          String   @id @default("singleton")
  siteName    String   @default("Dar Dmana")
  logoUrl     String?
  logoUrlDark String?
  faviconUrl  String?

  // Coordonnées globales (Navbar, Footer, page Contact).
  phone   String?
  whatsapp String?
  address String?
  email   String?

  // Réseaux sociaux (URLs).
  socialInstagram String?
  socialFacebook  String?
  socialTikTok    String?

  updatedAt   DateTime @updatedAt @default(now())
}

model HomepageSettings {
  // Singleton : contenu éditable de la page d'accueil.
  id String @id @default("singleton")

  heroTitleFr String?
  heroTitleAr String?
  heroTitleEn String?

  heroSubtitleFr String?
  heroSubtitleAr String?
  heroSubtitleEn String?

  announcementTextFr String?
  announcementTextAr String?
  announcementTextEn String?
  announcementActive Boolean @default(false)

  featuredProductIds String[]

  newsletterTitleFr String?
  newsletterTitleAr String?
  newsletterTitleEn String?

  updatedAt DateTime @updatedAt @default(now())
}

// ─── Livre d'Or — feed social de témoignages ────────────────────────────────────

enum GuestbookSource {
  WEBSITE
  WHATSAPP
  TIKTOK
  INSTAGRAM
}

enum MediaType {
  PHOTO
  VIDEO
}

model GuestbookEntry {
  id              String          @id @default(uuid())
  customerName    String
  customerCity    String?
  customerCountry String?         @default("MA")
  message         String          @db.Text
  rating          Int?
  mediaUrl        String?
  mediaType       MediaType?
  productTag      String?
  source          GuestbookSource @default(WEBSITE)
  likesCount      Int             @default(0)
  isVerifiedBuyer Boolean         @default(false)
  isApproved      Boolean         @default(false)
  isFeatured      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([isApproved, createdAt])
  @@index([isFeatured])
}

model BrandStats {
  id                 String   @id @default(uuid())
  tiktokFollowers    Int      @default(0)
  tiktokLikes        Int      @default(0)
  tiktokHandle       String?  @default("@dardmana")
  googleRating       Float?   @default(0)
  googleReviewsCount Int      @default(0)
  satisfactionRate   Float    @default(100)
  updatedAt          DateTime @updatedAt
  updatedBy          String?
}

model DeliverySettings {
  // Singleton : transporteur actif + clés API (chiffrées au repos).
  id             String   @id @default("singleton")
  activeProvider String   @default("MANUAL")
  amanaApiKey    String?
  ctmApiKey      String?
  updatedAt      DateTime @updatedAt @default(now())
  updatedBy      String?
}

enum AbandonedCartStatus {
  ACTIVE
  RECOVERED
  EXPIRED
}

model AbandonedCart {
  id             String              @id @default(uuid())
  email          String?
  phone          String?
  customerName   String?
  items          Json
  totalMad       Decimal
  status         AbandonedCartStatus @default(ACTIVE)
  remindersSent  Int                 @default(0)
  lastReminderAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

model CMSPage {
  id   String @id @default(cuid())
  slug String @unique

  titleFr String
  titleAr String
  titleEn String

  contentFr String
  contentAr String
  contentEn String

  // Médias éditables : image principale (banner) + galerie optionnelle.
  heroImageUrl  String?
  galleryImages String[]

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
