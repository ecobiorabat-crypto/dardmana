{
  "framework": "nextjs",
  "regions": ["cdg1"],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/abandoned-cart-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
